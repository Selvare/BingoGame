		DraftBoardSize: {
			Label: 已保存的棋盘边长
			Tooltip: 关闭 BINGO 窗体时保存。0 表示尚未保存草稿。
		}
	}

	BingoGameConfig: {
		DisplayName: 游戏配置

		DraftWinRule: {
			Label: 已保存的获胜规则
			Tooltip: 关闭 BINGO 窗体时保存。
		}

		DraftItemTypes: {
			Label: 已保存的棋盘物品 ID
			Tooltip: 关闭 BINGO 窗体时保存。0 表示由服务器随机填充的格子。
		}

		LineProgressTiebreakEnabled: {
			Label: 启用连线判定
			Tooltip: 连线规则结算平局时，优先比较各队最大连线进度。
		}

		LineAutoDegradeEnabled: {
			Label: 启用自动退化
			Tooltip: 连线进度仍相同时，继续比较总得分。
		}

		WhitelistEnabled: {
			Label: 启用白名单
			Tooltip: 启用后，随机格子只会从已启用白名单中选择物品。
		}

		Whitelists: {
			Label: 白名单
			Tooltip: 可在 BINGO 游戏设置内使用白名单编辑器维护。
		}

		TimeLimitEnabled: {
			Label: 启用限时
			Tooltip: 启用后，达到指定游戏时间时强制结算。
		}

		TimeLimitMinutes: {
			Label: 限时分钟
			// Tooltip: ""
		}

		TimeLimitSeconds: {
			Label: 限时秒数
			Tooltip: 必须为 0 到 59。
		}

		KillStealEnabled: {
			Label: 启用击杀夺取
			Tooltip: 启用后，不同队伍玩家 PVP 击杀时可使被击杀者掉落非初始物品。
		}

		KillStealChance: {
			Label: 击杀夺取概率
			Tooltip: 每个符合条件的物品独立判定，范围 0 到 1。
		}

		RandomStartEnabled: {
			Label: 启用开局随机
			Tooltip: 启用后，开局时玩家会随机传送。
		}

		RandomStartTeamTogether: {
			Label: 同队跟随随机
			Tooltip: 启用后，同队玩家会跟随队内首个在线玩家的随机落点。
		}

		ForcePvpEnabled: {
			Label: 启用 PVP 模式
			Tooltip: 启用后，对局进行中玩家会被强制设为 PVP。
		}

		NoRetreatEnabled: {
			Label: 启用死战不退
			Tooltip: 启用后，玩家受到其他队伍玩家伤害时会获得 5 秒死战不退，期间无法传送。
		}

		FogOfWarEnabled: {
			Label: 启用战争迷雾
			Tooltip: 启用后，地图不显示玩家头像和 BOSS 图标。
		}

		InitialItemLists: {
			Label: 初始物品列表
			Tooltip: 可在 BINGO 游戏设置内使用初始物品编辑器维护。
		}
	}

